# ─────────────────────────────────────────────────────────────────────────
# Picsou — bare-metal environment
#
# Zero-config first boot:
#   Run `./backend/scripts/picsou-init.sh > .env.local`, source it, then
#   `mvn spring-boot:run`. Everything else — admin user, CORS, Enable
#   Banking, etc. — is collected by the setup wizard at first launch.
#
# All values below are optional; set them only to override the defaults
# the wizard would otherwise ask you about.
# ─────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────
POSTGRES_DB=picsou
POSTGRES_USER=picsou
# POSTGRES_PASSWORD=           # leave blank → generated by picsou-init.sh

# ─── Secrets (auto-generated by picsou-init.sh if blank) ─────────────────
# JWT_SECRET=                  # openssl rand -base64 48
# CRYPTO_ENCRYPTION_KEY=       # openssl rand -base64 32

# ─── App credentials — configure via the setup wizard ────────────────────
# Only set these to skip the wizard (CI, automated provisioning).
# APP_USERNAME=admin
# APP_PASSWORD_HASH=$2a$12$REPLACE_WITH_REAL_BCRYPT_HASH

# ─── CORS — configure via the wizard ─────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:5173

# ─── Enable Banking — use the wizard's guided flow ───────────────────────
# Set these only if you already have credentials and a key pair.
# ENABLEBANKING_APPLICATION_ID=
# ENABLEBANKING_KEY_ID=
# ENABLEBANKING_REDIRECT_URI=http://localhost:5173/sync/callback
# ENABLEBANKING_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----

# ─── BoursoBank sidecar (optional override) ──────────────────────────────
# BOURSO_AUTH_URL=http://bourso-auth:8001

# ─── Secure cookies — the wizard detects this from your browser origin ──
# SECURE_COOKIES=true

# ─── Spring profile ──────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
