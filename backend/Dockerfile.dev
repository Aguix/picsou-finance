# Dev-only Dockerfile — Spring Boot with auto-reload on source changes
# 1. inotifywait watches src/ for modifications
# 2. Triggers mvn compile (incremental, ~3-5s)
# 3. DevTools detects class change and restarts Spring (~2-3s)
# Total: ~5-10s per change — not Vite-fast, but no Docker rebuild needed
FROM maven:3.9-eclipse-temurin-21-alpine

WORKDIR /app

RUN apk add --no-cache inotify-tools

COPY pom.xml .
RUN mvn dependency:go-offline -q

COPY src ./src
RUN mvn compile -q

COPY watch-and-compile.sh /app/watch-and-compile.sh
RUN chmod +x /app/watch-and-compile.sh

EXPOSE 8080 5005

CMD ["/app/watch-and-compile.sh"]
