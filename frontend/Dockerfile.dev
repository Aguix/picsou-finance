# Dev-only Dockerfile — runs Vite dev server with HMR
# Used automatically via docker-compose.override.yml
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install --quiet

COPY . .

EXPOSE 8080

# Vite dev server — proxies /api/* to backend, HMR on websocket
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "8080"]
